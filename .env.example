# DashScope（ASR / 对话 API）
DASHSCOPE_API_KEY=
# 可选：Qwen3 ASR Flash Realtime 使用 wss://…/api-ws/v1/realtime；新加坡地域可改为
# DASHSCOPE_REALTIME_WS_BASE=wss://dashscope-intl.aliyuncs.com/api-ws/v1/realtime
# DASHSCOPE_REALTIME_WS_BASE=

# 后端 HTTP 端口（默认 3002，与前端代理一致）
PORT=3002

# PostgreSQL（变量名须为 PG_*；旧版 OPC_PG_* 已不再读取）
PG_HOST=
PG_PORT=5432
PG_USER=
PG_PASSWORD=
PG_DATABASE=reso

# 初始化 / 补全表结构（读根目录 .env 的 PG_*，执行 bootstrap + migrations，可重复执行）
# npm run init-db

# Docker Compose（make docker-up）：库账号密码与 compose 中 POSTGRES_* 保持一致；也可在根目录 .env 里设 POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB
# 可选：WEB_PUBLISH_PORT=8080、SERVER_PUBLISH_PORT=3002、POSTGRES_PUBLISH_PORT=5432

# 以下为可选
# PG_SSL=1          仅当数据库强制 TLS / 公网握手异常时开启；普通实例勿开
# RESO_LOG=1            更详细的接口与访问日志
# RESO_LOG_HTTP=1       仅打印每条 HTTP 请求一行
# RESO_LOG_FILE=0       不写常规日志文件（默认 server/logs/reso.log）
# RESO_ERROR_LOG_FILE=0 不写错误日志（默认 server/logs/reso-errors.log，仅 serviceError）
# RESO_EXPOSE_ERRORS=1  500 响应附带 PostgreSQL 的 detail/pgCode（仅本地排错，勿上生产）
#
# Cursor CLI：工作台「关联 Cursor 对话」会在服务端执行 `agent create-chat`（需本机已安装 Cursor CLI 且在 PATH 中）。
# 若可执行文件名不是 agent，可指定绝对路径，例如：
# RESO_CURSOR_AGENT_BIN=/usr/local/bin/agent
#
# 远程 UI 控制（Agent / 自动化向浏览器推送白名单指令）：POST /api/ui-control/push，浏览器订阅 /ws/ui-control
# 若设置密钥，则推送接口需 Authorization: Bearer <密钥>，WebSocket subscribe 需带相同 token 字段。
# RESO_UI_CONTROL_SECRET=
# 前端生产构建启用订阅：VITE_UI_CONTROL_ENABLED=1；有密钥时构建注入 VITE_RESO_UI_CONTROL_TOKEN（与上相同）
