# DashScope（ASR / 对话 API）
DASHSCOPE_API_KEY=

# 后端 HTTP 端口（默认 3002，与前端代理一致）
PORT=3002

# PostgreSQL
OPC_PG_HOST=
OPC_PG_PORT=5432
OPC_PG_USER=
OPC_PG_PASSWORD=
OPC_PG_DATABASE=reso

# 以下为可选
# OPC_PG_SSL=1          仅当数据库强制 TLS / 公网握手异常时开启；普通实例勿开
# RESO_LOG=1            更详细的接口与访问日志
# RESO_LOG_HTTP=1       仅打印每条 HTTP 请求一行
# RESO_LOG_FILE=0       不写常规日志文件（默认 server/logs/reso.log）
# RESO_ERROR_LOG_FILE=0 不写错误日志（默认 server/logs/reso-errors.log，仅 serviceError）
# RESO_EXPOSE_ERRORS=1  500 响应附带 PostgreSQL 的 detail/pgCode（仅本地排错，勿上生产）
